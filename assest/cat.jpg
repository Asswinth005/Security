(var(--spacing)*6))] @w-lg/main:[--thread-content-margin:var(--thread-content-margin-lg,calc(var(--spacing)*16))] px-(--thread-content-margin)"><div class="[--thread-content-max-width:40rem] @w-lg/main:[--thread-content-max-width:48rem] mx-auto max-w-(--thread-content-max-width) flex-1 group/turn-messages focus-visible:outline-hidden relative flex w-full min-w-0 flex-col"><div class="flex max-w-full flex-col gap-4 grow"><div data-message-author-role="user" data-message-id="bbc8f548-46b8-49b0-8bfb-fa265f00b178" dir="auto" class="min-h-8 text-message relative flex w-full flex-col items-end gap-2 text-start break-words whitespace-normal outline-none keyboard-focused:focus-ring [.text-message+&amp;]:mt-1"><div class="flex w-full flex-col gap-1 empty:hidden items-end rtl:items-start"><div class="user-message-bubble-color corner-superellipse/0.98 relative rounded-[22px] px-4 py-2.5 leading-6 max-w-(--user-chat-width,70%)"><div class="whitespace-pre-wrap"> &lt;!-- ========== CORE VALUES ========== --&gt;
    &lt;section class="py-24 bg-white dark:bg-canvas-charcoal"&gt;
        &lt;div class="container mx-auto px-6"&gt;
            &lt;div class="text-center mb-14"&gt;
                &lt;span class="text-stratum font-mono text-sm tracking-widest border-l-4 border-stratum pl-3"&gt;PHILOSOPHY&lt;/span&gt;
                &lt;h2 class="text-4xl md:text-5xl font-display font-bold mt-4"&gt;What We &lt;span class="text-stratum"&gt;Stand For&lt;/span&gt;&lt;/h2&gt;
            &lt;/div&gt;
            &lt;div class="grid md:grid-cols-3 gap-8"&gt;
                &lt;div class="value-card text-center p-6 rounded-2xl transition-all hover:bg-stratum/5"&gt;
                    &lt;div class="value-icon w-16 h-16 bg-stratum/10 rounded-2xl flex items-center justify-center mx-auto mb-5"&gt;
                        &lt;i class="fas fa-hand-sparkles text-2xl text-stratum"&gt;&lt;/i&gt;
                    &lt;/div&gt;
                    &lt;h3 class="text-xl font-bold mb-2"&gt;Artisan Craftsmanship&lt;/h3&gt;
                    &lt;p class="text-gray-500 text-sm"&gt;Every pair is 100% hand-painted using premium Angelus leather paints and archival sealants.&lt;/p&gt;
                &lt;/div&gt;
                &lt;div class="value-card text-center p-6 rounded-2xl transition-all hover:bg-stratum/5"&gt;
                    &lt;div class="value-icon w-16 h-16 bg-stratum/10 rounded-2xl flex items-center justify-center mx-auto mb-5"&gt;
                        &lt;i class="fas fa-users text-2xl text-stratum"&gt;&lt;/i&gt;
                    &lt;/div&gt;
                    &lt;h3 class="text-xl font-bold mb-2"&gt;Artist Community&lt;/h3&gt;
                    &lt;p class="text-gray-500 text-sm"&gt;We champion emerging visual artists through residencies, collabs, and profit-sharing.&lt;/p&gt;
                &lt;/div&gt;
                &lt;div class="value-card text-center p-6 rounded-2xl transition-all hover:bg-stratum/5"&gt;
                    &lt;div class="value-icon w-16 h-16 bg-stratum/10 rounded-2xl flex items-center justify-center mx-auto mb-5"&gt;
                        &lt;i class="fas fa-leaf text-2xl text-stratum"&gt;&lt;/i&gt;
                    &lt;/div&gt;
                    &lt;h3 class="text-xl font-bold mb-2"&gt;Sustainable Ethos&lt;/h3&gt;
                    &lt;p class="text-gray-500 text-sm"&gt;Eco-friendly packaging, vegan paint options, and carbon-neutral shipping.&lt;/p&gt;
                &lt;/div&gt;
