<h3 data-section-id="8mj3rc" data-start="156" data-end="178">🔥 Bigger Options:</h3>
<ul data-start="179" data-end="291">
<li data-section-id="a89gpx" data-start="179" data-end="210">
<p data-start="181" data-end="210"><code data-start="181" data-end="190">text-lg</code> → slightly bigger</p>
</li>
<li data-section-id="7anuri" data-start="211" data-end="239">
<p data-start="213" data-end="239"><code data-start="213" data-end="222">text-xl</code> → medium large</p>
</li>
<li data-section-id="1kuxhpt" data-start="240" data-end="262">
<p data-start="242" data-end="262"><code data-start="242" data-end="252">text-2xl</code> → large</p>
</li>
<li data-section-id="1ojmwzu" data-start="263" data-end="291">
<p data-start="265" data-end="291"><code data-start="265" data-end="275">text-3xl</code> → extra large</p>
</li>
</ul>
